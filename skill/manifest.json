{
  "version": "3",
  "description": "Machine-readable registry of the design-to-code pipeline skills (paths relative to skill/). The system uses a minimal slice loop: design-check → design-plan (complex tasks) → design-to-slices → slice-implement ↔ slice-verify.",
  "layers": {
    "core": ["design-check", "design-plan", "design-to-slices", "slice-implement", "slice-verify"],
    "infra": ["run-init", "run-status"],
    "extensions": ["integration-verify", "result-curate"]
  },
  "skills": [
    {
      "name": "design-check",
      "path": "design-check/SKILL.md",
      "layer": "core",
      "predecessors": [],
      "primaryOutputs": [
        ".workflow/session/design-check.md"
      ]
    },
    {
      "name": "design-plan",
      "path": "design-plan/SKILL.md",
      "layer": "core",
      "predecessors": ["design-check"],
      "conditional": true,
      "condition": "complexity == complex",
      "primaryOutputs": [
        ".workflow/session/design-plan.md"
      ]
    },
    {
      "name": "design-to-slices",
      "path": "design-to-slices/SKILL.md",
      "layer": "core",
      "predecessors": ["design-check", "design-plan"],
      "primaryOutputs": [
        ".workflow/session/slices/index.md",
        ".workflow/session/slices/slice-<NNN>.md"
      ]
    },
    {
      "name": "slice-implement",
      "path": "slice-implement/SKILL.md",
      "layer": "core",
      "predecessors": ["design-to-slices"],
      "primaryOutputs": ["repository code and tests per slice scope"]
    },
    {
      "name": "slice-verify",
      "path": "slice-verify/SKILL.md",
      "layer": "core",
      "predecessors": ["slice-implement"],
      "primaryOutputs": [
        ".workflow/session/verify/slice-<NNN>-verify.md"
      ]
    },
    {
      "name": "run-init",
      "path": "run-init/SKILL.md",
      "layer": "infra",
      "predecessors": [],
      "primaryOutputs": [
        ".workflow/session/state.md",
        ".workflow/session/context.md",
        ".workflow/session/slices/",
        ".workflow/session/verify/"
      ]
    },
    {
      "name": "run-status",
      "path": "run-status/SKILL.md",
      "layer": "infra",
      "predecessors": [],
      "primaryOutputs": [
        "(read-only status summary, no file output by default)"
      ]
    },
    {
      "name": "integration-verify",
      "path": "integration-verify/SKILL.md",
      "layer": "extensions",
      "predecessors": ["slice-verify"],
      "primaryOutputs": [
        ".workflow/session/integration-report.md"
      ]
    },
    {
      "name": "result-curate",
      "path": "result-curate/SKILL.md",
      "layer": "extensions",
      "predecessors": ["integration-verify"],
      "primaryOutputs": [
        ".workflow/session/traceability-matrix.md",
        ".workflow/session/deviations-summary.md",
        ".workflow/session/final-index.md",
        ".workflow/session/next-iteration-context.md"
      ]
    }
  ]
}
